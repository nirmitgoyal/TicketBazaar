# Ticket Bazaar Environment Configuration
# Copy this file to .env and configure with your actual values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Database Configuration (Required)
# Get from NeonDB, PostgreSQL, or your database provider
DATABASE_URL="postgresql://username:password@host:port/database_name?sslmode=require"

# Session Security (Required)
# Generate a cryptographically secure random string (minimum 32 characters)
# You can generate one with: node scripts/generate-session-secret.js
SESSION_SECRET="your-cryptographically-secure-session-secret-here"

# Google Services (Required for core functionality)
# OAuth for authentication and Maps for location services
# Get from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Application Settings
NODE_ENV="development"
PORT="5000"
FRONTEND_URL="http://localhost:5000"

# Error Monitoring (Recommended for production)
# Get from Honeybadger: https://www.honeybadger.io/
HONEYBADGER_API_KEY="your-honeybadger-api-key"

# Payment Processing (Optional - for future payment integration)
# Stripe: https://stripe.com/
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# Razorpay: https://razorpay.com/
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_SECRET="your-razorpay-secret"

# Instagram OAuth (Optional - for enhanced verification)
# Get from Facebook Developers: https://developers.facebook.com/
INSTAGRAM_CLIENT_ID="your-instagram-client-id"
INSTAGRAM_CLIENT_SECRET="your-instagram-client-secret"

# Analytics (Optional)
# Google Analytics: https://analytics.google.com/
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Email Services (Optional - for notifications)
# SendGrid: https://sendgrid.com/
SENDGRID_API_KEY="SG.your-sendgrid-api-key"

# SMS Services (Optional - for phone verification)
# Twilio: https://www.twilio.com/
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# File Upload (Optional - for cloud storage)
# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_BUCKET_NAME="your-s3-bucket-name"
AWS_REGION="us-east-1"

# Redis (Optional - for session storage in production)
REDIS_URL="redis://localhost:6379"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Debug Settings
DEBUG="app:*"
LOG_LEVEL="debug"

# Development Database (Optional - separate from production)
DEV_DATABASE_URL="postgresql://username:password@localhost:5432/ticket_bazaar_dev"

# Test Database (Required for testing)
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/ticket_bazaar_test"

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production Security Settings
SECURE_COOKIES="true"
FORCE_HTTPS="true"
TRUST_PROXY="true"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# Session Settings
SESSION_MAX_AGE="86400000"  # 24 hours in milliseconds

# File Upload Limits
MAX_FILE_SIZE="5242880"  # 5MB in bytes
MAX_FILES_PER_REQUEST="3"

# =============================================================================
# API KEYS SETUP GUIDE
# =============================================================================

# Google Cloud Console Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google Maps JavaScript API
# 4. Enable Google+ API (for OAuth)
# 5. Create credentials:
#    - OAuth 2.0 Client ID for web application
#    - API Key for Maps (restrict to your domain)
# 6. Configure OAuth consent screen
# 7. Add authorized redirect URIs:
#    - http://localhost:5000/api/auth/google/callback (development)
#    - https://your-domain.com/api/auth/google/callback (production)

# NeonDB Setup:
# 1. Go to https://neon.tech/
# 2. Create account and new project
# 3. Copy connection string from dashboard
# 4. Ensure connection string includes ?sslmode=require

# Honeybadger Setup:
# 1. Go to https://www.honeybadger.io/
# 2. Create account and project
# 3. Copy API key from project settings
# 4. Configure error notifications

# Security Notes:
# - Never commit .env file to version control
# - Use different values for development/staging/production
# - Rotate secrets regularly
# - Use strong, unique passwords
# - Enable 2FA on all service accounts