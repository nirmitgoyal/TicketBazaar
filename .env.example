# Database Configuration
# Neon pooled URLs should keep sslmode=require.
DATABASE_URL=postgresql://username:password@ep-example-pooler.region.aws.neon.tech/database_name?sslmode=require&channel_binding=require

# Session Security
SESSION_SECRET=your-super-secret-session-key-here

# Neon Auth (Google social login)
NEON_AUTH_URL=https://ep-example.neonauth.region.aws.neon.tech/database_name/auth
VITE_NEON_AUTH_URL=https://ep-example.neonauth.region.aws.neon.tech/database_name/auth

# Legacy Google OAuth fallback (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback



# Google Maps API (Required for map functionality)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Feature Flags (Optional - control application features)
VITE_ENABLE_MAP_FEATURE=false

# Firebase Configuration (Required for analytics)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Instagram API (Optional - for verification features)
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Error Tracking (Optional - for production monitoring)
HONEYBADGER_API_KEY=your-honeybadger-api-key
HONEYBADGER_REVISION=your-git-revision

# WhatsApp Business API (Optional - for notifications)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id

# App Configuration
NODE_ENV=production
PORT=5000

# Rate Limiting Configuration (Optional - for disabling rate limits)
DISABLE_RATE_LIMITING=false
