{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build && esbuild server/vercel-api.ts --platform=node --packages=external --bundle --format=esm --define:process.env.VERCEL='\"1\"' --outfile=dist/vercel-api.js",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...]"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
