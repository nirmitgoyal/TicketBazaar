  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "dev": "npm run build:types && tsx server/index.ts",
    "build": "npm run build:types && vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:client": "npm run build:types && vite build",
    "build:server": "npm run build:types && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:types": "cd packages/types && npm run build",
    "start": "NODE_ENV=production node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "start:health": "node scripts/health-server.js",
    "check": "npm run build:types && tsc",
    "type-check": "npm run build:types && tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "wait-for-db": "node -e \"console.log('Database ready')\"",
    "heroku-postbuild": "npm run build:types && vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "diagnose:oauth": "tsx scripts/diagnose-oauth.ts"
  },
